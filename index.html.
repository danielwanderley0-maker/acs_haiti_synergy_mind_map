  'p6-5': {title:'P6-5: CARICOM-Latin America matching', desc:'CARICOM development entities + Latin American cooperation portfolios. ACS bridges both subregions\u2019 offers for priority Haitian sectors. Part of South-South cooperation cluster.'}
