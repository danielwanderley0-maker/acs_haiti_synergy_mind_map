<script>
const data = {
  'acs': {title:'ACS Cooperation Mechanism', desc:'The ACS sits at the center of 28 identified synergies across 6 pillars. Its role: convene, map, align, and amplify \u2014 not duplicate or replace operational agencies. Three action modes: (1) global/regional advocacy, (2) bilateral/plurilateral technical support mobilization, (3) project implementation.'},
